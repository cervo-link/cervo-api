{
  "name": "cervo-api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "tsc",
    "test": "bun --env-file=.env.test run vitest --config vitest.config.ts",
    "test:watch": "bun --env-file=.env.test run vitest --config vitest.config.ts --watch",
    "test:coverage": "bun --env-file=.env.test run vitest --config vitest.config.ts --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run drizzle-kit migrate",
    "db:migrate:test": "bun run drizzle-kit migrate --env-file .env.test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@faker-js/faker": "^9.9.0",
    "@types/argon2": "^0.15.4",
    "@types/bun": "latest",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "drizzle-kit": "^0.31.4",
    "testcontainers": "^11.6.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/otel": "^0.16.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@mendable/firecrawl-js": "^4.16.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.211.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.211.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.211.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.211.0",
    "@opentelemetry/host-metrics": "^0.38.2",
    "@opentelemetry/instrumentation-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-logs": "^0.211.0",
    "@opentelemetry/sdk-metrics": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.44.5",
    "drizzle-zod": "^0.8.3",
    "fastify": "^5.6.1",
    "fastify-type-provider-zod": "^6.0.0",
    "openai": "^6.33.0",
    "postgres": "^3.4.7",
    "scrapingbee": "^1.7.5",
    "uuid": "^11.1.0",
    "zod": "^4.3.4"
  }
}
