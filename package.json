{
  "name": "cervo-api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "tsc",
    "pretest": "bun run build",
    "test": "bun --env-file=.env.test run vitest --config vitest.config.ts",
    "test:watch": "bun --env-file=.env.test run vitest --config vitest.config.ts --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run drizzle-kit migrate",
    "db:migrate:test": "bun run drizzle-kit migrate --env-file .env.test",
    "lint": "biome lint src",
    "format": "biome format --write src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@faker-js/faker": "^9.9.0",
    "@types/bun": "latest",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "testcontainers": "^11.4.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "drizzle-orm": "^0.44.3",
    "fastify": "^5.6.0",
    "fastify-type-provider-zod": "^4.0.2",
    "postgres": "^3.4.7",
    "scrapingbee": "^1.7.5",
    "uuid": "^11.1.0",
    "zod": "^4.0.5"
  }
}
