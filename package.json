{
  "name": "cervo-api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch index.ts",
    "build": "tsc",
    "pretest": "bun run build",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run drizzle-kit migrate",
    "db:migrate:test": "bun run drizzle-kit migrate --env-file .env.test",
    "lint": "biome lint src",
    "format": "biome format --write src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@types/bun": "latest",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.3",
    "postgres": "^3.4.7",
    "uuid": "^11.1.0",
    "zod": "^4.0.5"
  }
}